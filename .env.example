# .env.example — copiá este archivo a .env y completá los valores
# El .env real está en .gitignore y NUNCA se sube al repo.

# ── WandB (Nicole — Fase 5) ──────────────────────────────────────────────────
WANDB_ENTITY=lozadaleonn
WANDB_PROJECT=rutacamba

# ── LLM para traducción (Jose — Fase 4) ─────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── AWS S3 para bajar modelos (Nicole — Fase 6) ──────────────────────────────
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_DEFAULT_REGION=us-east-1

# ── Puertos (opcionales, tienen defaults en config.py) ───────────────────────
# API_PORT=8000
# UI_PORT=7860
